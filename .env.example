# WalletConnect Project ID for RainbowKit
# Get one from https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your-project-id-here

# Private key for contract interactions (server-side)
# Use a dedicated wallet for production
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/atomic-settlement
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/atomic-settlement
MONGODB_URL=mongodb://localhost:27017/atomic-settlement